{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://lumensblock.dev/schemas/contract-graph.json",
  "title": "ContractGraph",
  "description": "Visual block graph for LumensBlock Soroban contract compilation.",
  "type": "object",
  "required": ["nodes", "edges"],
  "additionalProperties": false,
  "properties": {
    "nodes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": { "$ref": "#/definitions/node" }
    },
    "edges": {
      "type": "array",
      "maxItems": 200,
      "items": { "$ref": "#/definitions/edge" }
    }
  },
  "definitions": {
    "blockType": {
      "type": "string",
      "enum": ["default", "Condition", "Transfer", "Storage", "Event", "Auth"]
    },
    "node": {
      "type": "object",
      "required": ["id", "type", "data"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "$ref": "#/definitions/blockType" },
        "position": {
          "type": "object",
          "required": ["x", "y"],
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        },
        "data": {
          "type": "object",
          "required": ["label"],
          "properties": {
            "label": { "type": "string" },
            "params": {
              "type": "object",
              "properties": {
                "token": { "type": "string" },
                "storageKey": { "type": "string" },
                "eventName": { "type": "string" },
                "condition": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "edge": {
      "type": "object",
      "required": ["id", "source", "target"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "sourceHandle": { "type": ["string", "null"] },
        "targetHandle": { "type": ["string", "null"] }
      }
    }
  }
}
